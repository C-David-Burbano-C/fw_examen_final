{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "preDeployCommand": "cd reservas_laboratorios_carlos_luciana_alejandro && python manage.py migrate && python manage.py crear_usuarios_demo",
    "startCommand": "cd reservas_laboratorios_carlos_luciana_alejandro && python manage.py collectstatic --noinput && gunicorn seguimiento_proyectos_carlos_luciana_alejandro.wsgi:application --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
